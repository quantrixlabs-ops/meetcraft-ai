{
  "name": "meetcraft-ai",
  "private": true,
  "version": "1.3.0",
  "description": "AI-powered knowledge package generator",
  "author": "MeetCraft AI",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "server": "tsx server/index.ts",
    "client": "vite",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "vite build",
    "preview": "vite preview",
    "dev:desktop": "concurrently \"npm run server\" \"npm run client\" \"electron .\"",
    "build:desktop": "vite build && electron-builder",
    "dist": "electron-builder --publish never"
  },
  "dependencies": {
    "@google/genai": "^1.41.0",
    "@supabase/supabase-js": "^2.39.3",
    "@types/archiver": "^7.0.0",
    "@types/react-router-dom": "^5.3.3",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "lucide-react": "^0.563.0",
    "mermaid": "^10.9.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.17.2",
    "pptxgenjs": "3.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.14.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/pdfkit": "^0.17.5",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.meetcraft.ai",
    "productName": "MeetCraft AI",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "server/**/*",
      "node_modules/**/*",
      "package.json",
      "!**/test_upload.txt"
    ],
    "directories": {
      "buildResources": "electron"
    },
    "extraResources": [
      {
        "from": "server",
        "to": "server"
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
